# URL de base de l'API Kubo
# En dev : laisser /api pour utiliser le proxy Vite (évite les CORS)
# En prod : mettre l'URL complète ex: https://api.kubo.app/api
VITE_API_URL=/api

# Clé applicative (X-Api-Key) — obligatoire sur toutes les requêtes
# La clé ci-dessous est la clé de développement. La prod aura une clé différente.
VITE_API_KEY=
